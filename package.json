{
  "name": "reverse-mcp-tools",
  "version": "0.1.0",
  "description": "One-click installer for reverse-engineering MCP servers (Ghidra, JADX, x64dbg, jshook/Frida) into your MCP clients.",
  "type": "module",
  "bin": {
    "reverse-mcp-tools": "dist/index.js",
    "remcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "mcp",
    "reverse-engineering",
    "ghidra",
    "jadx",
    "x64dbg",
    "frida",
    "installer"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
